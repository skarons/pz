g='utf-8') as f2:\n","    data2 = list(map(int, f2.read().split()))\n","\n","positive_numbers = [x for x in data2 if x > 0]\n","positive_count = len(positive_numbers)\n","positive_sum = sum(positive_numbers)\n","\n","# Создание результирующего файла\n","with open('result21.txt', 'w', encoding='utf-8') as result:\n","    result.write('Содержимое первого файла:\\n')\n","    result.write(' '.join(map(str, data1)) + '\\n\\n')\n","\n","    result.write('Отрицательные элементы:\\n')\n","    result.write(' '.join(map(str, negative_numbers)) + '\\n')\n","\n","    result.write(f'Количество отрицательных элементов: {negative_count}\\n')\n","    result.write(f'Среднее арифметическое: {average_value:.2f}\\n\\n')\n","\n","    result.write('Содержимое второго файла:\\n')\n","    result.write(' '.join(map(str, data2)) + '\\n\\n')\n","\n","    result.write('Положительные элементы:\\n')\n","    result.write(' '.join(map(str, positive_numbers)) + '\\n')\n","\n","    result.write(f'Количество положительных элементов: {positive_count}\\n')\n","    result.write(f'Сумма положительных элементов: {positive_sum}\\n')\n","\n","print('Файл result21.txt успешно создан.')"]},{"cell_type":"code","source":["# 2.\n","# Из предложенного текстового файла (text18-21.txt)\n","# вывести на экран его содержимое,\n","# количество знаков препинания.\n","#\n","# Сформировать новый файл, в который поместить текст\n","# в стихотворной форме, выведя строки в обратном порядке.\n","\n","import string\n","\n","# Чтение файла\n","with open('text18-21.txt', 'r', encoding='utf-8') as file:\n","    lines = file.readlines()\n","\n","# Вывод содержимого файла\n","print('Содержимое файла:\\n')\n","\n","for line in lines:\n","    print(line, end='')\n","\n","# Подсчет знаков препинания\n","punctuation_count = 0\n","\n","for line in lines:\n","    for symbol in line:\n","        if symbol in string.punctuation + '«»—…':\n","            punctuation_count += 1\n","\n","print('\\n')\n","print('Количество знаков препинания:', punctuation_count)\n","\n","# Формирование нового файла с обратным порядком строк\n","reversed_lines = lines[::-1]\n","\n","with open('text18-21-result.txt', 'w', encoding='utf-8') as new_file:\n","    new_file.writelines(reversed_lines)\n","\n","print('Файл text18-21-result.txt успешно создан.')"],"metadata":{"id":"WpVpJ4UVi6tC","executionInfo":{"status":"error","timestamp":1780144799059,"user_tz":-180,"elapsed":23,"user":{"displayName":"Kirill Prokopenko","userId":"10055902542613811504"}},"outputId":"3c6234f0-81bd-4206-8362-4eec99e06f6e","colab":{"base_uri":"https://localhost:8080/","height":211}},"execution_count":2,"outputs":[{"output_type":"error","ename":"FileNotFoundError","evalue":"[Errno 2] No such file or directory: 'text18-21.txt'","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mFileNotFoundError\u001b[0m                         Traceback (most recent call last)","\u001b[0;32m/tmp/ipykernel_453/867768687.py\u001b[0m in \u001b[0;36m<cell line: 0>\u001b[0;34m()\u001b[0m\n\u001b[1;32m     10\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     11\u001b[0m \u001b[0;31m# Чтение файла\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m---> 12\u001b[0;31m \u001b[0;32mwith\u001b[0m \u001b[0mopen\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m'text18-21.txt'\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m'r'\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mencoding\u001b[0m\u001b[0;34m=\u001b[0m\u001b[0;34m'utf-8'\u001b[0m\u001b[0;34m)\u001b[0m \u001b[0;32mas\u001b[0m \u001b[0mfile\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m     13\u001b[0m     \u001b[0mlines\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mfile\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mreadlines\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     14\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n",