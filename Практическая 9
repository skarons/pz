к\n","not_caught_fish = lake_fish - caught_fish\n","\n","# Результат\n","print(\"\\nРезультаты:\")\n","print(\"Первый рыбак поймал:\", fisherman_1)\n","print(\"Второй рыбак поймал:\", fisherman_2)\n","print(\"Третий рыбак поймал:\", fisherman_3)\n","print(\"Не пойманы ни одним рыбаком:\", not_caught_fish)"]}]}